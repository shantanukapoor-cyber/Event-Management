# StadiumPulse Environment Variables
# Copy this file to .env and fill in values as needed.

# ─── Server ───────────────────────────────────────────
# Port for the Express server (default: 8080)
PORT=8080

# Node environment: "development" or "production"
NODE_ENV=development

# ─── Google Gemini API (optional) ─────────────────────
# If set, enables AI-powered "Explain why" for recommendations.
# If absent, the app uses a template-based fallback — fully functional.
# Get a free key at: https://aistudio.google.com/
GEMINI_API_KEY=

# ─── Google Sheets (optional) ─────────────────────────
# Public Google Sheet ID for venue configuration.
# If absent, uses bundled venueLayout.js data — fully functional.
# The sheet must be "Published to the web" (File → Share → Publish).
GOOGLE_SHEET_ID=

# ─── Simulator ────────────────────────────────────────
# PRNG seed for deterministic crowd simulation (default: 42)
SIMULATOR_SEED=42

# Match speed multiplier: 1 = real-time (90 min), 9 = accelerated (~10 min demo)
MATCH_SPEED=9

# ─── Rate Limiting ────────────────────────────────────
# Max explain requests per IP per minute (default: 10)
RATE_LIMIT_EXPLAIN=10

# Max general API requests per IP per minute (default: 60)
RATE_LIMIT_API=60
